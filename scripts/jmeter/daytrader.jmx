            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="User Register" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <stringProp name="HTTPSampler.path">/daytrader/app</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="action" elementType="HTTPArgument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">register</stringProp></elementProp>
                  <elementProp name="user_id" elementType="HTTPArgument"><stringProp name="Argument.name">user_id</stringProp><stringProp name="Argument.value">${USER_ID}</stringProp></elementProp>
                  <elementProp name="passwd" elementType="HTTPArgument"><stringProp name="Argument.name">passwd</stringProp><stringProp name="Argument.value">${UP}</stringProp></elementProp>
                  <elementProp name="full_name" elementType="HTTPArgument"><stringProp name="Argument.name">full_name</stringProp><stringProp name="Argument.value">TestUser</stringProp></elementProp>
                  <elementProp name="email" elementType="HTTPArgument"><stringProp name="Argument.name">email</stringProp><stringProp name="Argument.value">${USER_ID}@example.com</stringProp></elementProp>
                  <elementProp name="address" elementType="HTTPArgument"><stringProp name="Argument.name">address</stringProp><stringProp name="Argument.value">Test</stringProp></elementProp>
                  <elementProp name="credit_card" elementType="HTTPArgument"><stringProp name="Argument.name">credit_card</stringProp><stringProp name="Argument.value">${__Random(10000000,99999999,CC)}</stringProp></elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="User Login" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <stringProp name="HTTPSampler.path">/daytrader/app</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="action" elementType="HTTPArgument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">login</stringProp></elementProp>
                  <elementProp name="uid" elementType="HTTPArgument"><stringProp name="Argument.name">uid</stringProp><stringProp name="Argument.value">${USER_ID}</stringProp></elementProp>
                  <elementProp name="passwd" elementType="HTTPArgument"><stringProp name="Argument.name">passwd</stringProp><stringProp name="Argument.value">${UP}</stringProp></elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Quotes" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <stringProp name="HTTPSampler.path">/daytrader/app</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="action" elementType="HTTPArgument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">quotes</stringProp></elementProp>
                  <elementProp name="symbols" elementType="HTTPArgument"><stringProp name="Argument.name">symbols</stringProp><stringProp name="Argument.value">${SYMBOL}</stringProp></elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Buy Stock" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <stringProp name="HTTPSampler.path">/daytrader/app</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="action" elementType="HTTPArgument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">buy</stringProp></elementProp>
                  <elementProp name="symbol" elementType="HTTPArgument"><stringProp name="Argument.name">symbol</stringProp><stringProp name="Argument.value">${SYMBOL}</stringProp></elementProp>
                  <elementProp name="quantity" elementType="HTTPArgument"><stringProp name="Argument.name">quantity</stringProp><stringProp name="Argument.value">${QUANTITY}</stringProp></elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree/>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Portfolio" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <stringProp name="HTTPSampler.path">/daytrader/app</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="action" elementType="HTTPArgument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">portfolio</stringProp></elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract HOLDINGID" enabled="true">
                <stringProp name="RegexExtractor.useHeaders">false</stringProp>
                <stringProp name="RegexExtractor.refname">HOLDINGID</stringProp>
                <stringProp name="RegexExtractor.regex">(?i)(?:holdingid|holdingId|holdingID)=([0-9]+)</stringProp>
                <stringProp name="RegexExtractor.template">$1$</stringProp>
                <stringProp name="RegexExtractor.default">NO_HOLDING</stringProp>
                <stringProp name="RegexExtractor.match_number">1</stringProp>
              </RegexExtractor>
              <hashTree/>
            </hashTree>
          </hashTree>
        </hashTree>

        <!-- Variant C (20%): Wealth-Management: Login -> Portfolio -> SellStock -> AccountInfo -->
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="IF Variant=C (WealthManagement)" enabled="true">
          <stringProp name="IfController.condition">${__groovy(vars.get('DT_VARIANT')=='C')}</stringProp>
        </IfController>
        <hashTree>
          <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="VC_WealthManagement" enabled="true">
            <boolProp name="TransactionController.parent">true</boolProp>
            <boolProp name="TransactionController.includeTimers">true</boolProp>
          </TransactionController>
          <hashTree>
            <BeanShellSampler guiclass="BeanShellSamplerGui" testclass="BeanShellSampler" testname="Generate User (UUID + RandomPass)" enabled="true">
              <stringProp name="BeanShellSampler.query"><![CDATA[
vars.put("USER_ID", "u_" + java.util.UUID.randomUUID().toString().replace("-", ""));
vars.put("UP", String.valueOf((int)(Math.random()*900000) + 100000));
]]></stringProp>
            </BeanShellSampler>
            <hashTree/>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="User Register" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <stringProp name="HTTPSampler.path">/daytrader/app</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="action" elementType="HTTPArgument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">register</stringProp></elementProp>
                  <elementProp name="user_id" elementType="HTTPArgument"><stringProp name="Argument.name">user_id</stringProp><stringProp name="Argument.value">${USER_ID}</stringProp></elementProp>
                  <elementProp name="passwd" elementType="HTTPArgument"><stringProp name="Argument.name">passwd</stringProp><stringProp name="Argument.value">${UP}</stringProp></elementProp>
                  <elementProp name="full_name" elementType="HTTPArgument"><stringProp name="Argument.name">full_name</stringProp><stringProp name="Argument.value">TestUser</stringProp></elementProp>
                  <elementProp name="email" elementType="HTTPArgument"><stringProp name="Argument.name">email</stringProp><stringProp name="Argument.value">${USER_ID}@example.com</stringProp></elementProp>
                  <elementProp name="address" elementType="HTTPArgument"><stringProp name="Argument.name">address</stringProp><stringProp name="Argument.value">Test</stringProp></elementProp>
                  <elementProp name="credit_card" elementType="HTTPArgument"><stringProp name="Argument.name">credit_card</stringProp><stringProp name="Argument.value">${__Random(10000000,99999999,CC)}</stringProp></elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree/>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="User Login" enabled="true">
              <stringProp name="HTTPSampler.method">GET</stringProp>
