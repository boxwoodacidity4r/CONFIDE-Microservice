            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="REST - Book Flight (F2)" enabled="true">
              <stringProp name="HTTPSampler.path">/rest/api/bookings/bookflights</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
