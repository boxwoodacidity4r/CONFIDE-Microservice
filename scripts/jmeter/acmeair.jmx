            </HTTPSamplerProxy>
            <hashTree>
              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract ToFlightId (F2)" enabled="true">
                <stringProp name="JSONPostProcessor.referenceNames">ACME_TO_FLIGHT_ID</stringProp>
                <stringProp name="JSONPostProcessor.jsonPathExprs">$[0].flightId</stringProp>
