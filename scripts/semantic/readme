# 进入工具目录并构建项目
cd tools
mvn clean package -DskipTests

# 要开vpn 语义抽取（解析源码 -> method-level semantic.json）jdk11
python scripts/semantic/run_semantic_extraction.py

# Embedding 抽取（semantic.json -> *.pt + *_class_embeddings.json）
# 默认启用：
# - architecture_stopwords（技术停用词）
#不要开vpn - Domain-Focus Filter hard list（impl/service/dao/... 等）
切到 legacy：$env:MM_DISTILL_MODE="legacy"
python scripts/semantic/run_embedding_extraction.py--distill_mode legacy

# -----------------------------
# Reproducible knobs (可复现开关)
# -----------------------------
# 说明：extract_embeddings.py 会在 embedding 目录写出 *_semantic_params.json 记录本次过滤参数。
#
# A) 关闭 Domain-Focus Filter hard list（保留 arch stopwords）
# python scripts/semantic/extract_embeddings.py --input data/processed/semantic/acmeair_semantic.json --output data/processed/embedding/acmeair.pt --no-domain-focus
#
# B) 追加自定义 domain stopwords（更激进地净化）
# python scripts/semantic/extract_embeddings.py --input data/processed/semantic/acmeair_semantic.json --output data/processed/embedding/acmeair.pt --extra-domain-stopwords "facade,delegate,assembler"
#
# C) 批处理入口：用环境变量统一控制四系统（PowerShell 示例）
#   $env:MM_NO_DOMAIN_FOCUS=1
#   $env:MM_EXTRA_DOMAIN_STOPWORDS='facade,delegate'
#   $env:MM_NO_ARCH_STOPWORDS=0
#   $env:MM_EXTRA_ARCH_STOPWORDS=''
#   python scripts/semantic/run_embedding_extraction.py
#
# D) 关闭所有 stopwords（不推荐，仅做 ablation）
#   $env:MM_NO_ARCH_STOPWORDS=1
#   $env:MM_NO_DOMAIN_FOCUS=1
#   python scripts/semantic/run_embedding_extraction.py








