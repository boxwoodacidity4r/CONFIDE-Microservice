# Phase 2: EDL 训练与推理流程命令

> 本阶段采用 **每个系统单独训练**（model + scaler 均按系统分别生成），以避免跨系统特征分布差异带来的不公平与不稳定。

## 1. 生成训练特征（含标准化器）
# 建议 downsample=2（可按数据量调整）
python scripts/multimodal/phase2/prepare_edl_data.py --system acmeair   --downsample 2 --save_scaler data/processed/edl/acmeair_scaler.pkl
python scripts/multimodal/phase2/prepare_edl_data.py --system daytrader --downsample 2 --save_scaler data/processed/edl/daytrader_scaler.pkl
python scripts/multimodal/phase2/prepare_edl_data.py --system jpetstore --downsample 2 --save_scaler data/processed/edl/jpetstore_scaler.pkl
python scripts/multimodal/phase2/prepare_edl_data.py --system plants   --downsample 2 --save_scaler data/processed/edl/plants_scaler.pkl

## 2. 训练 EDL 模型（每系统单独训练）
python scripts/multimodal/phase2/edl_train.py --train_X data/processed/edl/acmeair_X.npy   --train_y data/processed/edl/acmeair_y.npy   --save data/processed/edl/edl_model_acmeair.pt
python scripts/multimodal/phase2/edl_train.py --train_X data/processed/edl/daytrader_X.npy --train_y data/processed/edl/daytrader_y.npy --save data/processed/edl/edl_model_daytrader.pt
python scripts/multimodal/phase2/edl_train.py --train_X data/processed/edl/jpetstore_X.npy --train_y data/processed/edl/jpetstore_y.npy --save data/processed/edl/edl_model_jpetstore.pt
python scripts/multimodal/phase2/edl_train.py --train_X data/processed/edl/plants_X.npy   --train_y data/processed/edl/plants_y.npy   --save data/processed/edl/edl_model_plants.pt

# 可选：更长的训练（示例，只需按需对某个系统启用）
# python scripts/multimodal/phase2/edl_train.py --train_X data/processed/edl/acmeair_X.npy --train_y data/processed/edl/acmeair_y.npy --epochs 60 --batch 512 --lr 5e-4 --save data/processed/edl/edl_model_acmeair.pt

## 3. 生成推理特征（全对）
python scripts/multimodal/phase2/prepare_inference_data.py acmeair
python scripts/multimodal/phase2/prepare_inference_data.py daytrader
python scripts/multimodal/phase2/prepare_inference_data.py jpetstore
python scripts/multimodal/phase2/prepare_inference_data.py plants

## 4. 推理（每系统使用各自 model + scaler）
python scripts/multimodal/phase2/edl_infer.py --X data/processed/edl/acmeair_all_X.npy   --model data/processed/edl/edl_model_acmeair.pt   --class_order data/processed/fusion/acmeair_class_order.json   --scaler data/processed/edl/acmeair_scaler.pkl   --out data/processed/edl/acmeair_edl_uncertainty.npy
python scripts/multimodal/phase2/edl_infer.py --X data/processed/edl/daytrader_all_X.npy --model data/processed/edl/edl_model_daytrader.pt --class_order data/processed/fusion/daytrader_class_order.json --scaler data/processed/edl/daytrader_scaler.pkl --out data/processed/edl/daytrader_edl_uncertainty.npy
python scripts/multimodal/phase2/edl_infer.py --X data/processed/edl/jpetstore_all_X.npy --model data/processed/edl/edl_model_jpetstore.pt --class_order data/processed/fusion/jpetstore_class_order.json --scaler data/processed/edl/jpetstore_scaler.pkl --out data/processed/edl/jpetstore_edl_uncertainty.npy
python scripts/multimodal/phase2/edl_infer.py --X data/processed/edl/plants_all_X.npy   --model data/processed/edl/edl_model_plants.pt   --class_order data/processed/fusion/plants_class_order.json   --scaler data/processed/edl/plants_scaler.pkl   --out data/processed/edl/plants_edl_uncertainty.npy
