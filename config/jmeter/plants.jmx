<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="PlantsByWebSphere Full Coverage Test Plan v3 - A (Enhanced for microservice extraction)" enabled="true">
      <stringProp name="TestPlan.comments">Enhanced: dynamic ViewState &amp; itemId extraction, full POST flows, timers, headers, cookies.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments">
        <collectionProp name="Arguments.arguments">
          <elementProp name="username" elementType="Argument">
            <stringProp name="Argument.name">username</stringProp>
            <stringProp name="Argument.value">plant</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="password" elementType="Argument">
            <stringProp name="Argument.name">password</stringProp>
            <stringProp name="Argument.value">plant</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="admin_user" elementType="Argument">
            <stringProp name="Argument.name">admin_user</stringProp>
            <stringProp name="Argument.value">dev</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="admin_pass" elementType="Argument">
            <stringProp name="Argument.name">admin_pass</stringProp>
            <stringProp name="Argument.value">dev</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"/>
    </TestPlan>

    <hashTree>
      <!-- HTTP Defaults -->
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Request Defaults" enabled="true">
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
        <stringProp name="HTTPSampler.domain">localhost</stringProp>
        <stringProp name="HTTPSampler.port">8084</stringProp>
        <stringProp name="HTTPSampler.protocol">http</stringProp>
        <stringProp name="HTTPSampler.contentEncoding"></stringProp>
        <stringProp name="HTTPSampler.path"></stringProp>
      </ConfigTestElement>
      <hashTree/>

      <!-- Header Manager -->
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="header_user_agent" elementType="Header">
            <stringProp name="Header.name">User-Agent</stringProp>
            <stringProp name="Header.value">Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/142.0.0.0 Safari/537.36</stringProp>
          </elementProp>
          <elementProp name="header_accept" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
            <stringProp name="Header.value">text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8</stringProp>
          </elementProp>
          <elementProp name="header_accept_language" elementType="Header">
            <stringProp name="Header.name">Accept-Language</stringProp>
            <stringProp name="Header.value">zh-CN,zh;q=0.9</stringProp>
          </elementProp>
          <elementProp name="header_origin" elementType="Header">
            <stringProp name="Header.name">Origin</stringProp>
            <stringProp name="Header.value">http://localhost:8084</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>

      <!-- Cookie Manager -->
      <CookieManager guiclass="CookiePanel" testclass="CookieManager" testname="HTTP Cookie Manager" enabled="true">
        <boolProp name="CookieManager.clearEachIteration">false</boolProp>
        <collectionProp name="CookieManager.cookies"/>
      </CookieManager>
      <hashTree/>

      <!-- HTTP Authorization Manager (Admin) -->
      <AuthManager guiclass="AuthPanel" testclass="AuthManager" testname="HTTP Authorization Manager" enabled="true">
        <collectionProp name="AuthManager.auth_list">
          <elementProp name="auth_1" elementType="Authorization">
            <stringProp name="Authorization.url">http://localhost:8084/PlantsByWebSphere/</stringProp>
            <stringProp name="Authorization.username">${admin_user}</stringProp>
            <stringProp name="Authorization.password">${admin_pass}</stringProp>
            <stringProp name="Authorization.domain"></stringProp>
            <stringProp name="Authorization.realm"></stringProp>
          </elementProp>
        </collectionProp>
      </AuthManager>
      <hashTree/>

      <!-- ===== Thread Group: User (realistic full flow) ===== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="User Actions Thread Group - Full Flow" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">5</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
      </ThreadGroup>
      <hashTree>
        <!-- Random Think Time for realism -->
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think Time Random Timer" enabled="true">
          <!-- base delay 300ms, random range 700ms => 300..1000 ms -->
          <stringProp name="ConstantTimer.delay">300</stringProp>
          <stringProp name="RandomTimer.range">700</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- 1) Home / Promo Page (GET) -->
        <HTTPSamplerProxy testname="Home / Promo Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.domain"></stringProp>
          <stringProp name="HTTPSampler.port"></stringProp>
          <stringProp name="HTTPSampler.protocol"></stringProp>
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/promo.jsf</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 2) Shopping page (GET) => extract itemID & viewState -->
        <HTTPSamplerProxy testname="Shopping Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/shopping.jsf</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Extract ViewState from shopping page -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract ViewState (from shopping)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">viewState</stringProp>
            <stringProp name="RegexExtractor.regex">javax\.faces\.ViewState"\s*value="(.+?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>
          <!-- Extract itemID from shopping page -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract itemID (from shopping)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">itemID</stringProp>
            <stringProp name="RegexExtractor.regex">name="itemID"\s*value="([^\"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NO_ITEM</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 3) Product page POST (simulate clicking product -> server responds with new ViewState) -->
        <HTTPSamplerProxy testname="Product Page (POST - view product / add form)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/product.jsf</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <!-- quantity -->
              <elementProp name="product:quantity" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">product:quantity</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <!-- product submit button (as in capture) -->
              <elementProp name="product_SUBMIT" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">product_SUBMIT</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <!-- dynamic ViewState captured from shopping GET -->
              <elementProp name="javax.faces.ViewState" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">javax.faces.ViewState</stringProp>
                <stringProp name="HTTPArgument.value">${viewState}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <!-- itemID captured from shopping GET -->
              <elementProp name="itemID" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">itemID</stringProp>
                <stringProp name="HTTPArgument.value">${itemID}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <!-- JSF idcl param (from capture) -->
              <elementProp name="product:_idcl" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">product:_idcl</stringProp>
                <stringProp name="HTTPArgument.value">product:j_id_29</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- After product POST, extract new viewState (for subsequent add-to-cart if needed) -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract ViewState (from product response)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">viewState</stringProp>
            <stringProp name="RegexExtractor.regex">javax\.faces\.ViewState"\s*value="(.+?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>
          <!-- also ensure itemID is present/updated -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract itemID (from product response)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">itemID</stringProp>
            <stringProp name="RegexExtractor.regex">name="itemID"\s*value="([^\"]+)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NO_ITEM</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>
        </hashTree>

        <!-- 4) Add To Cart (POST) - uses itemID + viewState + add submit/idcl -->
        <HTTPSamplerProxy testname="Add To Cart (POST)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/shopping.jsf</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <!-- shopping_SUBMIT and viewState/itemID per your capture -->
              <elementProp name="shopping_SUBMIT" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">shopping_SUBMIT</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="javax.faces.ViewState" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">javax.faces.ViewState</stringProp>
                <stringProp name="HTTPArgument.value">${viewState}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="itemID" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">itemID</stringProp>
                <stringProp name="HTTPArgument.value">${itemID}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="shopping:_idcl" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">shopping:_idcl</stringProp>
                <stringProp name="HTTPArgument.value">shopping:j_id_1n_2_6</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- update viewState after add-to-cart -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract ViewState (after add-to-cart)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">viewState</stringProp>
            <stringProp name="RegexExtractor.regex">javax\.faces\.ViewState"\s*value="(.+?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
        </hashTree>

        <!-- 5) Cart Page (GET) -->
        <HTTPSamplerProxy testname="Cart Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/cart.jsf</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 6) Login (POST) - uses viewState + credentials -->
        <HTTPSamplerProxy testname="User Login (POST)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/login.jsf</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="login:email" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">login:email</stringProp>
                <stringProp name="HTTPArgument.value">plants@plantsbywebsphere.ibm.com</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="login:password" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">login:password</stringProp>
                <stringProp name="HTTPArgument.value">plants</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="login_SUBMIT" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">login_SUBMIT</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="javax.faces.ViewState" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">javax.faces.ViewState</stringProp>
                <stringProp name="HTTPArgument.value">${viewState}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="login:_idcl" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">login:_idcl</stringProp>
                <stringProp name="HTTPArgument.value">login:j_id_1r</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- capture viewState after login -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract ViewState (after login)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">viewState</stringProp>
            <stringProp name="RegexExtractor.regex">javax\.faces\.ViewState"\s*value="(.+?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
        </hashTree>

        <!-- 7) Order Info (POST) - fill address, card, etc. -->
        <HTTPSamplerProxy testname="Order Info (POST)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/orderinfo.jsf</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <!-- billing/shipping fields from your capture -->
              <elementProp name="orderinfo:bname" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">orderinfo:bname</stringProp>
                <stringProp name="HTTPArgument.value">David Grover</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="orderinfo:baddr1" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">orderinfo:baddr1</stringProp>
                <stringProp name="HTTPArgument.value">123 Main Street</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <!-- ... include other orderinfo fields (city/state/zip/phone, shipping, card details) -->
              <elementProp name="orderinfo_SUBMIT" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">orderinfo_SUBMIT</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="javax.faces.ViewState" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">javax.faces.ViewState</stringProp>
                <stringProp name="HTTPArgument.value">${viewState}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="orderinfo:_idcl" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">orderinfo:_idcl</stringProp>
                <stringProp name="HTTPArgument.value">orderinfo:j_id_4r</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract ViewState (after orderinfo)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">viewState</stringProp>
            <stringProp name="RegexExtractor.regex">javax\.faces\.ViewState"\s*value="(.+?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
        </hashTree>

        <!-- 8) Checkout Final (POST) -->
        <HTTPSamplerProxy testname="Final Checkout (POST)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/checkout_final.jsf</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="checkout_final:cartTable:0:quantity" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">checkout_final:cartTable:0:quantity</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="checkout_final_SUBMIT" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">checkout_final_SUBMIT</stringProp>
                <stringProp name="HTTPArgument.value">1</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="javax.faces.ViewState" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">javax.faces.ViewState</stringProp>
                <stringProp name="HTTPArgument.value">${viewState}</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
              <elementProp name="checkout_final:_idcl" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.name">checkout_final:_idcl</stringProp>
                <stringProp name="HTTPArgument.value">checkout_final:j_id_3l</stringProp>
                <stringProp name="HTTPArgument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract ViewState (after checkout_final)" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">viewState</stringProp>
            <stringProp name="RegexExtractor.regex">javax\.faces\.ViewState"\s*value="(.+?)"</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
        </hashTree>

        <!-- 9) Order Done Page (GET) -->
        <HTTPSamplerProxy testname="Order Done Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/orderdone.jsf</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- 10) Account / Help pages (GET) -->
        <HTTPSamplerProxy testname="Account Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/account.jsf</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
        <HTTPSamplerProxy testname="Help Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/help.jsf</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

      <!-- ===== Thread Group: Admin (keeps as in your original plan) ===== -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Admin Actions Thread Group" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">2</stringProp>
        <stringProp name="ThreadGroup.ramp_time">3</stringProp>
      </ThreadGroup>
      <hashTree>
        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Admin Think Time" enabled="true">
          <stringProp name="ConstantTimer.delay">300</stringProp>
          <stringProp name="RandomTimer.range">500</stringProp>
        </UniformRandomTimer>
        <hashTree/>
        <HTTPSamplerProxy testname="Admin Home Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/admin.html</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
        <HTTPSamplerProxy testname="Admin Actions Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/adminactions.html</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
        <HTTPSamplerProxy testname="Admin Banner Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/adminbanner.html</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
        <HTTPSamplerProxy testname="Backorder Admin Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/backorderadmin.jsp</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
        <HTTPSamplerProxy testname="Supplier Config Page (GET)" guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" enabled="true">
          <stringProp name="HTTPSampler.path">/PlantsByWebSphere/supplierconfig.jsp</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>
      </hashTree>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
